<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================ -->
    <!-- COLOR PALETTE — Douze Assistance v2                              -->
    <!-- ================================================================ -->

    <!-- Backgrounds — true blacks -->
    <Color x:Key="BgApp">#FF0B0B0B</Color>
    <Color x:Key="BgBar">#FF0E0E0E</Color>
    <Color x:Key="BgPanel">#FF111111</Color>
    <Color x:Key="BgCard">#FF161616</Color>
    <Color x:Key="BgPage">#FF0B0B0B</Color>
    <Color x:Key="BgButton">#FF1C1C1C</Color>
    <Color x:Key="BgButtonHover">#FF252525</Color>
    <Color x:Key="BgButtonActive">#FF166534</Color>

    <!-- Borders -->
    <Color x:Key="BorderSubtle">#FF1E1E1E</Color>
    <Color x:Key="BorderNormal">#FF2A2A2A</Color>
    <Color x:Key="BorderLight">#FF383838</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#FFF5F5F5</Color>
    <Color x:Key="TextSecondary">#FFA3A3A3</Color>
    <Color x:Key="TextMuted">#FF525252</Color>
    <Color x:Key="TextActive">#FFFFFFFF</Color>

    <!-- Accents -->
    <Color x:Key="AccentGreen">#FF22C55E</Color>
    <Color x:Key="AccentGreenDark">#FF166534</Color>
    <Color x:Key="AccentGreenMuted">#FF14532D</Color>
    <Color x:Key="AccentRed">#FFEF4444</Color>
    <Color x:Key="AccentOrange">#FFF59E0B</Color>
    <Color x:Key="AccentBlue">#FF3B82F6</Color>
    <Color x:Key="AccentPurple">#FFA855F7</Color>

    <!-- Racing class colors -->
    <Color x:Key="ClassLMP">#FFFF2D55</Color>
    <Color x:Key="ClassGTE">#FF00C7BE</Color>
    <Color x:Key="ClassGT3">#FFFF9F0A</Color>

    <!-- ================================================================ -->
    <!-- BRUSHES                                                          -->
    <!-- ================================================================ -->
    <SolidColorBrush x:Key="BgAppBrush"           Color="{StaticResource BgApp}"/>
    <SolidColorBrush x:Key="BgBarBrush"           Color="{StaticResource BgBar}"/>
    <SolidColorBrush x:Key="BgPanelBrush"         Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgCardBrush"          Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgPageBrush"          Color="{StaticResource BgApp}"/>
    <SolidColorBrush x:Key="BgButtonBrush"        Color="{StaticResource BgButton}"/>
    <SolidColorBrush x:Key="BgButtonHoverBrush"   Color="{StaticResource BgButtonHover}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderNormalBrush"    Color="{StaticResource BorderNormal}"/>
    <SolidColorBrush x:Key="BorderLightBrush"     Color="{StaticResource BorderLight}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"     Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentGreenDarkBrush" Color="{StaticResource AccentGreenDark}"/>
    <SolidColorBrush x:Key="AccentRedBrush"       Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentBlueBrush"      Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush"    Color="{StaticResource AccentOrange}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush"    Color="{StaticResource AccentPurple}"/>

    <!-- Legacy aliases (overlays + code-behind use these) -->
    <SolidColorBrush x:Key="BgDarkBrush"          Color="{StaticResource BgApp}"/>
    <SolidColorBrush x:Key="BgMediumBrush"        Color="{StaticResource BgBar}"/>
    <SolidColorBrush x:Key="BgLightBrush"         Color="{StaticResource BgButton}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderNormal}"/>
    <SolidColorBrush x:Key="BorderHoverBrush"     Color="{StaticResource BorderLight}"/>
    <SolidColorBrush x:Key="AccentGreenMutedBrush" Color="{StaticResource AccentGreenMuted}"/>

    <!-- ================================================================ -->
    <!-- OVERLAY WINDOW STYLE                                             -->
    <!-- ================================================================ -->
    <Style x:Key="OverlayWindowStyle" TargetType="Window">
        <Setter Property="WindowStyle"        Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="Topmost"            Value="True"/>
        <Setter Property="ShowInTaskbar"      Value="False"/>
        <Setter Property="ResizeMode"         Value="NoResize"/>
    </Style>

    <!-- ================================================================ -->
    <!-- OVERLAY PANEL                                                    -->
    <!-- ================================================================ -->
    <Style x:Key="OverlayPanel" TargetType="Border">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding"      Value="10"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BgApp}" Opacity="0.90"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderNormal}" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.5" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- TYPOGRAPHY                                                       -->
    <!-- ================================================================ -->
    <Style x:Key="OverlayTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>

    <Style x:Key="OverlayValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="OverlayValueLarge" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Consolas"/>
        <Setter Property="FontSize"    Value="22"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="OverlayLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <!-- ================================================================ -->
    <!-- TOGGLE SWITCH STYLE                                              -->
    <!-- ================================================================ -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="36" Height="20" Cursor="Hand">
                        <Border x:Name="Track" CornerRadius="10"
                                Background="{StaticResource BgButtonBrush}"
                                BorderBrush="{StaticResource BorderNormalBrush}" BorderThickness="1"/>
                        <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7"
                                Background="{StaticResource TextMutedBrush}"
                                HorizontalAlignment="Left" Margin="3,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"  Value="{StaticResource AccentGreenDarkBrush}"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                            <Setter TargetName="Thumb" Property="Background"  Value="{StaticResource AccentGreenBrush}"/>
                            <Setter TargetName="Thumb" Property="Margin"      Value="19,0,0,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- SIDEBAR CHECKBOX                                                 -->
    <!-- ================================================================ -->
    <Style x:Key="SidebarCheckBox" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Box" Width="15" Height="15" CornerRadius="3"
                            Background="{StaticResource BgButtonBrush}"
                            BorderBrush="{StaticResource BorderNormalBrush}" BorderThickness="1">
                        <TextBlock x:Name="Check" Text="✓" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box"   Property="Background"  Value="{StaticResource AccentGreenMutedBrush}"/>
                            <Setter TargetName="Box"   Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                            <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- MODERN SLIDER                                                    -->
    <!-- ================================================================ -->
    <Style x:Key="ModernSlider" TargetType="Slider">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Height="2" CornerRadius="1"
                                Background="{StaticResource BgButtonBrush}"
                                VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="14" Height="14"
                                                     Fill="{StaticResource AccentGreenBrush}"
                                                     Cursor="Hand"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- FLAT TOGGLE BUTTON — action bar + general purpose               -->
    <!-- ================================================================ -->
    <Style x:Key="FlatToggle" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BgButtonBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderNormalBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="10,6"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"   Value="{StaticResource BgButtonHoverBrush}"/>
                            <Setter TargetName="bg" Property="BorderBrush"  Value="{StaticResource BorderLightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- NAV TAB BUTTON — top navigation tabs                            -->
    <!-- ================================================================ -->
    <Style x:Key="NavTab" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="24,0"/>
        <Setter Property="Height"          Value="42"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="Transparent"
                            BorderThickness="0,0,0,2"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgButtonBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- PRIMARY BUTTON — connect / main CTA                             -->
    <!-- ================================================================ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource AccentGreenDarkBrush}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="16,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- DARK COMBOBOX                                                    -->
    <!-- ================================================================ -->
    <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background"      Value="#FF161616"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding"         Value="9,5"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#FF252525"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentGreenMutedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
        <Setter Property="Background"         Value="#FF161616"/>
        <Setter Property="Foreground"         Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"        Value="{StaticResource BorderNormalBrush}"/>
        <Setter Property="BorderThickness"    Value="1"/>
        <Setter Property="Cursor"             Value="Hand"/>
        <Setter Property="MaxDropDownHeight"  Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Full-area toggle button (handles click) -->
                        <ToggleButton x:Name="ToggleButton"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False" ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bg"
                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            CornerRadius="3">
                                        <TextBlock Text="▾" Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="9" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="BorderBrush"
                                                    Value="{StaticResource BorderLightBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bg" Property="BorderBrush"
                                                    Value="{StaticResource AccentGreenBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- Selected item text -->
                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="9,0,26,0"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="None">
                            <Border Background="#FF161616"
                                    BorderBrush="{StaticResource BorderNormalBrush}" BorderThickness="1"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Background="Transparent">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!-- SECONDARY BUTTON                                                 -->
    <!-- ================================================================ -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource FlatToggle}"/>

    <!-- ================================================================ -->
    <!-- TAB CONTROL (unused but kept for compat)                        -->
    <!-- ================================================================ -->
    <Style x:Key="ModernTabControl" TargetType="TabControl">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="ModernTabItem" TargetType="TabItem">
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="Padding"     Value="14,8"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                            Background="Transparent" Margin="2,0">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush"     Value="{StaticResource AccentGreenBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{StaticResource BgButtonBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
