<UserControl x:Class="LMUOverlay.Views.ChronoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ChronoBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FF1C1C1C"/>
            <Setter Property="Foreground"      Value="#FFA3A3A3"/>
            <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF252525"/>
                                <Setter Property="BorderBrush" Value="#FF383838"/>
                                <Setter Property="Foreground"  Value="#FFF5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChronoInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#FF161616"/>
            <Setter Property="Foreground"      Value="#FFF5F5F5"/>
            <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="#FF22C55E"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF0B0B0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar / settings -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
            <RowDefinition Height="*"/>     <!-- Table -->
        </Grid.RowDefinitions>

        <!-- ══ TOOLBAR ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FF0E0E0E"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="12,10">
            <StackPanel>
                <!-- Line 1: game folder -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="DOSSIER RESULTS" FontSize="11" FontWeight="Bold"
                               FontFamily="Segoe UI Semibold" Foreground="#FF525252"
                               Width="150" VerticalAlignment="Center"/>
                    <Button x:Name="BtnBrowse" Content="PARCOURIR" Click="OnBrowse"
                            Style="{StaticResource ChronoBtn}" DockPanel.Dock="Right"
                            Margin="6,0,0,0"/>
                    <TextBox x:Name="TbGameFolder" Style="{StaticResource ChronoInput}"
                             ToolTip="Ex : C:\Program Files (x86)\Steam\steamapps\common\Le Mans Ultimate\UserData\Log\Results"
                             TextChanged="OnSettingChanged"/>
                </DockPanel>

                <!-- Line 2: player name + refresh -->
                <DockPanel>
                    <TextBlock Text="NOM IN-GAME (exact)" FontSize="11" FontWeight="Bold"
                               FontFamily="Segoe UI Semibold" Foreground="#FF525252"
                               Width="150" VerticalAlignment="Center"/>
                    <Button x:Name="BtnRefresh" Content="⟳ ACTUALISER" Click="OnRefresh"
                            Style="{StaticResource ChronoBtn}" DockPanel.Dock="Right"
                            Margin="6,0,0,0" Foreground="#FF22C55E"/>
                    <TextBox x:Name="TbPlayerName" Style="{StaticResource ChronoInput}"
                             ToolTip="Entrez exactement votre nom tel qu'il apparaît dans le jeu"
                             TextChanged="OnSettingChanged"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ══ STATUS BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#FF0B0B0B"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="12,5">
            <DockPanel>
                <TextBlock x:Name="TbStatus"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="#FF525252"/>
                <TextBlock x:Name="TbResultPath"
                           FontSize="9" FontFamily="Consolas"
                           Foreground="#FF383838"
                           DockPanel.Dock="Right"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ══ TABLE AREA ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>  <!-- frozen circuit column -->
                <ColumnDefinition Width="*"/>    <!-- scrollable data -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Circuit column (frozen) ──────────────────────────── -->
            <DockPanel Grid.Column="0"
                       Background="#FF0E0E0E"
                       LastChildFill="True">

                <!-- Double-height header to align with class + car rows on the right -->
                <Border DockPanel.Dock="Top"
                        Background="#FF111111"
                        BorderBrush="#FF1E1E1E" BorderThickness="0,0,1,1">
                    <TextBlock Text="CIRCUIT"
                               FontSize="13" FontWeight="Bold"
                               FontFamily="Segoe UI Semibold"
                               Foreground="#FF525252"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Height="58"/>
                </Border>

                <ScrollViewer x:Name="LeftScroll"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="CircuitList"/>
                </ScrollViewer>
            </DockPanel>

            <!-- ── RIGHT: Data table (scrollable horizontally + vertically) ── -->
            <Border Grid.Column="1"
                    BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,0">
                <ScrollViewer x:Name="RightScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="OnRightScrollChanged">
                    <StackPanel x:Name="DataTable"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Empty state overlay -->
        <Border Grid.Row="2" x:Name="EmptyState"
                Background="Transparent"
                Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="CHRONO"
                           FontSize="32" FontWeight="Bold"
                           FontFamily="Consolas"
                           Foreground="#FF1A1A1A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock x:Name="TbEmptyHint"
                           Text="Entrez le dossier du jeu et votre nom in-game, puis cliquez sur ACTUALISER."
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="#FF383838"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="420"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
