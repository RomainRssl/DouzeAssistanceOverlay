<UserControl x:Class="LMUOverlay.Views.VoicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="VoiceBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FF1C1C1C"/>
            <Setter Property="Foreground"      Value="#FFA3A3A3"/>
            <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#FF252525"/>
                                <Setter Property="BorderBrush" Value="#FF383838"/>
                                <Setter Property="Foreground"  Value="#FFF5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF0B0B0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── TOOLBAR ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF0E0E0E"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel>
                <TextBlock Text="ALERTES VOCALES" FontFamily="Segoe UI Semibold"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#FF525252"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" Margin="4,0,0,0"/>
                <Button x:Name="BtnTest" Content="🔊 TEST" Click="OnTest"
                        Style="{StaticResource VoiceBtn}"
                        DockPanel.Dock="Right"
                        Foreground="#FF22C55E"/>
            </DockPanel>
        </Border>

        <!-- ─── BODY ─────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="48,32,48,32" MaxWidth="560">

                <!-- ══ GÉNÉRAL ══════════════════════════════════════════ -->
                <TextBlock Text="GÉNÉRAL" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#FF383838" Margin="0,0,0,12"/>

                <!-- Toggle activé -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Alertes vocales activées" FontSize="11"
                                   FontFamily="Segoe UI" Foreground="#FFF5F5F5"/>
                        <TextBlock Text="Désactivé par défaut — activer pour entendre les alertes"
                                   FontSize="9" FontFamily="Segoe UI"
                                   Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkEnabled" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>

                <Border Height="1" Background="#FF1E1E1E" Margin="0,4,0,14"/>

                <!-- Pack vocal -->
                <TextBlock Text="Pack vocal (fichiers .wav)" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#FF525252" Margin="0,0,0,4"/>
                <TextBlock FontSize="9" FontFamily="Segoe UI" Foreground="#FF383838" Margin="0,0,0,6"
                           TextWrapping="Wrap">
                    <Run>Déposez vos .wav dans</Run>
                    <Run x:Name="RunVoiceDir" Foreground="#FF22C55E" FontFamily="Consolas" FontSize="9"/>
                </TextBlock>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CbVoicePack" Height="30"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="OnVoicePackChanged"/>
                    <Button x:Name="BtnOpenVoiceDir" Content="📁" Grid.Column="1"
                            Style="{StaticResource VoiceBtn}"
                            Click="OnOpenVoiceDir" Margin="4,0,0,0" Padding="8,5"
                            ToolTip="Ouvrir le dossier des packs vocaux"/>
                    <Button x:Name="BtnRefreshPacks" Content="↺" Grid.Column="2"
                            Style="{StaticResource VoiceBtn}"
                            Click="OnRefreshPacks" Margin="4,0,0,0" Padding="8,5"
                            ToolTip="Actualiser la liste des packs"/>
                </Grid>
                <Border Height="1" Background="#FF1E1E1E" Margin="0,10,0,10"/>

                <!-- Voix système (TTS fallback) -->
                <TextBlock Text="Voix TTS (si pas de .wav)" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#FF525252" Margin="0,0,0,6"/>
                <ComboBox x:Name="CbVoice" Height="30"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="OnVoiceChanged"
                          Margin="0,0,0,14"/>

                <!-- Volume -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Volume" FontSize="11" FontFamily="Segoe UI"
                               Foreground="#FFA3A3A3" VerticalAlignment="Center"/>
                    <Slider x:Name="SlVolume" Grid.Column="1"
                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnVolumeChanged"/>
                    <TextBlock x:Name="TbVolume" Grid.Column="2"
                               FontSize="11" FontFamily="Consolas"
                               Foreground="#FF22C55E"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Vitesse -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Vitesse de parole" FontSize="11" FontFamily="Segoe UI"
                               Foreground="#FFA3A3A3" VerticalAlignment="Center"/>
                    <Slider x:Name="SlRate" Grid.Column="1"
                            Minimum="-5" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnRateChanged"/>
                    <TextBlock x:Name="TbRate" Grid.Column="2"
                               FontSize="11" FontFamily="Consolas"
                               Foreground="#FF22C55E"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#FF1E1E1E" Margin="0,18,0,14"/>

                <!-- ══ CATÉGORIES D'ALERTES ══════════════════════════════ -->
                <TextBlock Text="CATÉGORIES D'ALERTES" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#FF383838" Margin="0,0,0,12"/>

                <!-- Carburant -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Carburant" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Fenêtre de pit, carburant bas, critique" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkFuel" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>
                <!-- Cooldown carburant critique -->
                <Grid Margin="16,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Répétition critique" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownFuel" Grid.Column="1"
                            Minimum="10" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownFuel" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Drapeaux -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Drapeaux" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Bleu, jaune, rouge, vert, damier" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkFlags" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>
                <!-- Cooldowns drapeaux -->
                <Grid Margin="16,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Répétition drapeau bleu" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownBlue" Grid.Column="1"
                            Minimum="5" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownBlue" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="16,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Répétition drapeau jaune" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownYellow" Grid.Column="1"
                            Minimum="10" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownYellow" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Gap -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Gap" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Voiture proche derrière, décrochage devant" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkGap" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>
                <!-- Cooldown gap -->
                <Grid Margin="16,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Répétition alerte gap" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownGap" Grid.Column="1"
                            Minimum="5" Maximum="60" TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownGap" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Tours -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tours" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Meilleur tour personnel, meilleurs secteurs" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkLap" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>

                <!-- Position -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Position" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Position gagnée ou perdue en course" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkPosition" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>
                <!-- Cooldown position -->
                <Grid Margin="16,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Répétition position" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownPosition" Grid.Column="1"
                            Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownPosition" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Spotter -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Spotter" FontSize="11" FontFamily="Segoe UI" Foreground="#FFA3A3A3"/>
                        <TextBlock Text="Voiture à gauche, à droite, des deux côtés, dégagé" FontSize="9"
                                   FontFamily="Segoe UI" Foreground="#FF525252" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkSpotter" Grid.Column="1" VerticalAlignment="Center"
                              Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                </Grid>
                <!-- Cooldown spotter -->
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Cooldown min. spotter" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#FF525252" VerticalAlignment="Center"/>
                    <Slider x:Name="SlCooldownSpotter" Grid.Column="1"
                            Minimum="1" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnCooldownChanged"/>
                    <TextBlock x:Name="TbCooldownSpotter" Grid.Column="2"
                               FontSize="10" FontFamily="Consolas" Foreground="#FF525252"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#FF1E1E1E" Margin="0,18,0,14"/>

                <!-- ══ RÉGLAGES GAP ══════════════════════════════════════ -->
                <TextBlock Text="RÉGLAGES" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           Foreground="#FF383838" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Seuil gap (secondes)" FontSize="11" FontFamily="Segoe UI"
                               Foreground="#FFA3A3A3" VerticalAlignment="Center"/>
                    <Slider x:Name="SlGapThreshold" Grid.Column="1"
                            Minimum="0.2" Maximum="5.0" TickFrequency="0.1"
                            VerticalAlignment="Center" ValueChanged="OnGapThresholdChanged"/>
                    <TextBlock x:Name="TbGapThreshold" Grid.Column="2"
                               FontSize="11" FontFamily="Consolas"
                               Foreground="#FF22C55E"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#FF1E1E1E" Margin="0,24,0,20"/>

                <!-- ══ SAUVEGARDE ════════════════════════════════════════ -->
                <Button Content="💾 SAUVEGARDER" Click="OnSave"
                        Style="{StaticResource VoiceBtn}"
                        FontSize="11" FontWeight="Bold"
                        Foreground="#FF22C55E" BorderBrush="#FF166534"
                        Padding="20,8" HorizontalAlignment="Left"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
