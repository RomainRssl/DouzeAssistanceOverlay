<UserControl x:Class="LMUOverlay.Views.ClassementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 — Identité (prénom / nom / discord) -->
        <Border Grid.Row="0" Background="#FF0E0E0E"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="14,8">
            <DockPanel>
                <TextBlock Text="CLASSEMENT EN LIGNE" FontSize="9" FontWeight="Bold"
                           FontFamily="Segoe UI Semibold" Foreground="#FF22C55E"
                           VerticalAlignment="Center" Margin="0,0,20,0"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF22C55E" VerticalAlignment="Center"
                               Margin="0,0,12,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnRefresh" Content="⟳ ACTUALISER"
                            Style="{StaticResource FlatToggle}" FontSize="9"
                            Padding="10,4" Margin="0,0,6,0"
                            Click="OnRefresh"/>
                    <Button Content="💾 SAVE"
                            Style="{StaticResource FlatToggle}" FontSize="9"
                            Padding="10,4" Foreground="#FF22C55E"
                            Click="OnSave"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PRÉNOM" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF525252" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox x:Name="TbPrenom" Width="100" Height="26"
                             FontFamily="Consolas" FontSize="10"
                             Background="#FF161616" Foreground="#FFF5F5F5"
                             BorderBrush="#FF2A2A2A" BorderThickness="1"
                             Padding="8,3" MaxLength="30" Margin="0,0,14,0"/>

                    <TextBlock Text="NOM" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF525252" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox x:Name="TbNom" Width="100" Height="26"
                             FontFamily="Consolas" FontSize="10"
                             Background="#FF161616" Foreground="#FFF5F5F5"
                             BorderBrush="#FF2A2A2A" BorderThickness="1"
                             Padding="8,3" MaxLength="30" Margin="0,0,14,0"/>

                    <TextBlock Text="DISCORD" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF525252" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox x:Name="TbDiscord" Width="130" Height="26"
                             FontFamily="Consolas" FontSize="10"
                             Background="#FF161616" Foreground="#FFF5F5F5"
                             BorderBrush="#FF2A2A2A" BorderThickness="1"
                             Padding="8,3" MaxLength="50"
                             ToolTip="Ex: TonPseudo#1234"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ROW 1 — Filtres classes -->
        <Border Grid.Row="1" Background="#FF0B0B0B"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="14,6">
            <DockPanel>
                <TextBlock x:Name="StatsText" FontSize="9" FontFamily="Consolas"
                           Foreground="#FF383838" VerticalAlignment="Center"
                           DockPanel.Dock="Right"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CATÉGORIE :" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF383838" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel x:Name="FilterPanel" Orientation="Horizontal"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ROW 2 — États / classement -->
        <Grid Grid.Row="2" Background="#FF0B0B0B">

            <TextBlock x:Name="LoadingText" Text="Chargement du classement..."
                       FontSize="12" FontFamily="Consolas" Foreground="#FF383838"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <StackPanel x:Name="ErrorPanel" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" FontSize="11" FontFamily="Consolas"
                           Foreground="#FFff4466" TextAlignment="Center"/>
                <TextBlock Text="Vérifie ta connexion et que le serveur est démarré."
                           FontSize="9" FontFamily="Consolas" Foreground="#FF525252"
                           TextAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel x:Name="EmptyPanel" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="Aucune donnée disponible."
                           FontSize="11" FontFamily="Consolas" Foreground="#FF383838"
                           TextAlignment="Center"/>
                <TextBlock Text="Complète un tour valide en jeu pour apparaître au classement."
                           FontSize="9" FontFamily="Consolas" Foreground="#FF525252"
                           TextAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <TextBlock x:Name="ConfigNeededText"
                       Text="Entre ton prénom, ton nom et ton pseudo Discord ci-dessus, puis clique SAVE."
                       FontSize="11" FontFamily="Consolas" Foreground="#FF383838"
                       TextWrapping="Wrap" MaxWidth="500"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" Visibility="Collapsed"/>

            <ScrollViewer x:Name="RankingsScroll" VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <StackPanel x:Name="RankingsPanel" Margin="24,16,24,24"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
