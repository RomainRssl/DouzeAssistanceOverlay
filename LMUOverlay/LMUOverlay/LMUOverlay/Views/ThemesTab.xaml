<UserControl x:Class="LMUOverlay.Views.ThemesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- LEFT — Theme list                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#FF0E0E0E"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#FF0B0B0B"
                        BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <TextBlock Text="THÈMES DISPONIBLES" FontSize="9" FontWeight="Bold"
                               FontFamily="Segoe UI Semibold" Foreground="#FF383838"/>
                </Border>

                <!-- Action buttons -->
                <Border DockPanel.Dock="Bottom" Background="#FF0B0B0B"
                        BorderBrush="#FF1E1E1E" BorderThickness="0,1,0,0"
                        Padding="8,6">
                    <WrapPanel>
                        <Button x:Name="BtnNew"       Content="+ NOUVEAU"  Click="OnNew"
                                Style="{StaticResource FlatToggle}" Margin="2"/>
                        <Button x:Name="BtnDuplicate" Content="DUPLIQUER"  Click="OnDuplicate"
                                Style="{StaticResource FlatToggle}" Margin="2"/>
                        <Button x:Name="BtnImport"    Content="IMPORTER"   Click="OnImport"
                                Style="{StaticResource FlatToggle}" Margin="2"/>
                        <Button x:Name="BtnExportFile" Content="EXPORTER"  Click="OnExportFile"
                                Style="{StaticResource FlatToggle}" Margin="2"/>
                        <Button x:Name="BtnDelete"    Content="SUPPRIMER"  Click="OnDelete"
                                Style="{StaticResource FlatToggle}" Margin="2"
                                Foreground="#FFEF4444"/>
                    </WrapPanel>
                </Border>

                <!-- Theme list -->
                <ListBox x:Name="ThemeList" Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="OnThemeSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="Foreground"  Value="#FF828282"/>
                            <Setter Property="Padding"     Value="12,7"/>
                            <Setter Property="FontFamily"  Value="Consolas"/>
                            <Setter Property="FontSize"    Value="11"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#26346234"/>
                                    <Setter Property="Foreground" Value="#FF22C55E"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0F22C55E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- RIGHT — Editor + preview                                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="#FF0B0B0B">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Scrollable editor -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          Padding="20,16,20,8">
                <StackPanel x:Name="EditorPanel" MaxWidth="680"/>
            </ScrollViewer>

            <!-- Preview panel -->
            <Border Grid.Row="1" Background="#FF0E0E0E"
                    BorderBrush="#FF1E1E1E" BorderThickness="0,1,0,0"
                    Padding="20,10">
                <StackPanel>
                    <TextBlock Text="APERÇU" FontSize="8" FontWeight="Bold"
                               FontFamily="Segoe UI Semibold" Foreground="#FF383838"
                               Margin="0,0,0,6"/>
                    <Border x:Name="PreviewBorder" CornerRadius="4" Padding="12,8"
                            Width="340" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Header label -->
                            <TextBlock Grid.Column="0" x:Name="PreviewLabel"
                                       Text="VITESSE" FontSize="9"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- Speed value + bar -->
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PreviewValue"
                                           Text="231 KM/H" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Left"/>
                                <Border x:Name="PreviewBarBg" Height="6" CornerRadius="3" Margin="0,4,0,0">
                                    <Border x:Name="PreviewBarFill" Width="200"
                                            HorizontalAlignment="Left" CornerRadius="3"/>
                                </Border>
                            </StackPanel>

                            <!-- Status dots -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock x:Name="PreviewGood"   Text="● GOOD"   FontSize="9" Margin="0,1"/>
                                <TextBlock x:Name="PreviewWarn"   Text="● WARN"   FontSize="9" Margin="0,1"/>
                                <TextBlock x:Name="PreviewDanger" Text="● DANGER" FontSize="9" Margin="0,1"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Action bar -->
            <Border Grid.Row="2" Background="#FF0E0E0E"
                    BorderBrush="#FF1E1E1E" BorderThickness="0,1,0,0"
                    Padding="20,8">
                <DockPanel>
                    <TextBlock x:Name="StatusMsg" FontSize="10" FontFamily="Consolas"
                               Foreground="#FF22C55E" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button x:Name="BtnReset"  Content="RÉINITIALISER" Click="OnReset"
                                Style="{StaticResource FlatToggle}" Margin="0,0,4,0"/>
                        <Button x:Name="BtnCancel" Content="ANNULER"       Click="OnCancel"
                                Style="{StaticResource FlatToggle}" Margin="0,0,4,0"/>
                        <Button x:Name="BtnSave"   Content="💾 SAUVEGARDER" Click="OnSave"
                                Style="{StaticResource FlatToggle}" Margin="0"
                                Foreground="#FF22C55E"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
