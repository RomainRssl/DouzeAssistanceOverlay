<Window x:Class="LMUOverlay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DOUZE ASSISTANCE"
        Width="920" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#FF1A1A1A"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header + tabs -->
            <RowDefinition Height="Auto"/>  <!-- action grid (HUD only) -->
            <RowDefinition Height="*"/>     <!-- main content -->
            <RowDefinition Height="Auto"/>  <!-- footer status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- ROW 0 — HEADER + TAB NAVIGATION                             -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Background="#FF222222" BorderBrush="#FF3A3A3A"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- LEFT: Logo + name -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                            VerticalAlignment="Center" Margin="10,6">
                    <Image Source="pack://application:,,,/Resources/logo.png"
                           Width="58" Height="58" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DOUZE ASSISTANCE" FontSize="13" FontWeight="Bold"
                                   Foreground="#FFDDDDDD" FontFamily="Segoe UI Semibold"/>
                        <TextBlock Text="Le Mans Ultimate Overlay" FontSize="8"
                                   Foreground="#FF666666"/>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: version + status + connect -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="9"
                               Foreground="#FF555555" VerticalAlignment="Center"
                               Margin="0,0,12,0" Cursor="Hand"
                               ToolTip="Cliquer pour vérifier les mises à jour"
                               MouseLeftButtonDown="OnCheckUpdates"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusText" FontSize="10" FontFamily="Consolas"
                               Foreground="#FF888888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="BtnConnect" Content="CONNECT" Click="OnConnect"
                            Style="{StaticResource PrimaryButton}" FontSize="10"/>
                </StackPanel>

                <!-- CENTER: Section tabs -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Stretch" DockPanel.Dock="Left">
                    <Button x:Name="TabHud" Content="HUD" Click="OnTabHud"
                            Style="{StaticResource FlatToggle}"
                            Background="#FF2E5A2E" Foreground="White"
                            FontSize="11" FontWeight="Bold" Padding="22,0"
                            BorderThickness="0" Height="38"/>
                    <Button x:Name="TabTelemetry" Content="TELEMETRY" Click="OnTabTelemetry"
                            Style="{StaticResource FlatToggle}"
                            Background="Transparent" Foreground="#FF666666"
                            BorderBrush="Transparent" BorderThickness="0"
                            FontSize="11" FontWeight="Bold" Padding="22,0" Height="38"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- ROW 1 — ACTION BUTTONS (HUD mode only)                      -->
        <!-- ============================================================ -->
        <Border x:Name="HudActions" Grid.Row="1" Background="#FF1E1E1E"
                BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1" Padding="6,5">
            <UniformGrid Columns="4" Rows="2">
                <Button x:Name="BtnLock"      Content="LOCK HUD"       Click="OnToggleLock"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button Content="TOUT AFFICHER"   Click="OnShowAll"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button Content="TOUT MASQUER"    Click="OnHideAll"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button x:Name="BtnVR"        Content="VR MODE"        Click="OnToggleVR"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button x:Name="BtnHideMenus" Content="MASQUER MENUS"  Click="OnToggleHideMenus"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button Content="SAVE"            Click="OnSave"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button Content="EXPORT CSV"      Click="OnExport"
                        Style="{StaticResource FlatToggle}" Margin="3,2"/>
                <Button Content="ALWAYS VISIBLE"  Click="OnShowAll"
                        Style="{StaticResource FlatToggle}" Margin="3,2"
                        Foreground="#FF555555"/>
            </UniformGrid>
        </Border>

        <!-- ============================================================ -->
        <!-- ROW 2 — MAIN CONTENT                                        -->
        <!-- ============================================================ -->
        <Grid Grid.Row="2">

            <!-- HUD: sidebar + settings panel -->
            <Grid x:Name="HudGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="165"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Overlay list -->
                <Border Grid.Column="0" Background="#FF1E1E1E"
                        BorderBrush="#FF3A3A3A" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Header -->
                        <Border DockPanel.Dock="Top" Background="#FF222222"
                                BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1"
                                Padding="8,5">
                            <TextBlock Text="OVERLAYS" FontSize="9" FontWeight="Bold"
                                       FontFamily="Segoe UI Semibold"
                                       Foreground="#FF666666"/>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="SidebarPanel" Margin="0,2"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- RIGHT: Settings panel -->
                <Border Grid.Column="1" Background="#FF1A1A1A">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,8">
                        <StackPanel x:Name="SettingsPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- TELEMETRY panel (hidden by default) -->
            <local:TelemetryPanel x:Name="TelPanel" Visibility="Collapsed"
                                  xmlns:local="clr-namespace:LMUOverlay.Views"/>
        </Grid>

        <!-- ============================================================ -->
        <!-- ROW 3 — STATUS BAR                                          -->
        <!-- ============================================================ -->
        <Border Grid.Row="3" Background="#FF1E1E1E" BorderBrush="#FF3A3A3A"
                BorderThickness="0,1,0,0" Padding="10,4">
            <DockPanel>
                <!-- Right: overlay count + version -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveCountText" FontSize="9" FontFamily="Consolas"
                               Foreground="#FF44AA44" Margin="0,0,12,0"/>
                    <TextBlock Text="Douze Assistance" FontSize="9" Foreground="#FF444444"/>
                </StackPanel>

                <!-- Left: status indicators -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Shared Memory" FontSize="9" Foreground="#FF666666" Margin="0,0,4,0"/>
                    <Ellipse x:Name="ShmDot" Width="7" Height="7" Margin="0,0,14,0"/>
                    <TextBlock x:Name="TrackText" FontSize="9" Foreground="#FF555555" FontFamily="Consolas"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
