<UserControl x:Class="LMUOverlay.Views.TelemetryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>

        <!-- Channel checkbox -->
        <Style x:Key="ChanCb" TargetType="CheckBox">
            <Setter Property="Foreground"        Value="#FFA3A3A3"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,8,0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FFF5F5F5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFF5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toolbar button -->
        <Style x:Key="TelBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FF1C1C1C"/>
            <Setter Property="Foreground"      Value="#FFA3A3A3"/>
            <Setter Property="BorderBrush"     Value="#FF2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF252525"/>
                                <Setter Property="BorderBrush" Value="#FF383838"/>
                                <Setter Property="Foreground"  Value="#FFF5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#FF0B0B0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── TOOLBAR ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF0E0E0E"
                BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">

                    <!-- Record toggle -->
                    <Button x:Name="BtnRecord" Click="OnToggleRecording"
                            Style="{StaticResource TelBtn}" Margin="0,0,6,0"/>

                    <Border Width="1" Background="#FF1E1E1E" Margin="0,2,8,2"/>

                    <!-- Export / Import -->
                    <Button x:Name="BtnExport" Content="💾 EXPORT" Click="OnExport"
                            Style="{StaticResource TelBtn}" Margin="0,0,4,0"/>
                    <Button x:Name="BtnImport" Content="📂 IMPORTER" Click="OnImport"
                            Style="{StaticResource TelBtn}" Margin="0,0,4,0"/>
                    <Button Content="⟲ ZOOM" Click="OnResetZoom"
                            Style="{StaticResource TelBtn}" Margin="0,0,8,0"/>

                    <Border Width="1" Background="#FF1E1E1E" Margin="0,2,8,2"/>

                    <!-- Channel checkboxes -->
                    <TextBlock Text="Canaux :" Foreground="#FF525252"
                               FontFamily="Segoe UI" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox x:Name="CbSpeed"    Content="Vitesse"   Tag="Speed"    IsChecked="True"
                              Style="{StaticResource ChanCb}"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                    <CheckBox x:Name="CbThrottle" Content="Gaz"       Tag="Throttle"
                              Style="{StaticResource ChanCb}"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                    <CheckBox x:Name="CbBrake"    Content="Frein"     Tag="Brake"
                              Style="{StaticResource ChanCb}"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                    <CheckBox x:Name="CbRPM"      Content="RPM"       Tag="RPM"
                              Style="{StaticResource ChanCb}"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                    <CheckBox x:Name="CbGear"     Content="Rapport"   Tag="Gear"
                              Style="{StaticResource ChanCb}"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                    <CheckBox x:Name="CbSteering" Content="Direction" Tag="Steering"
                              Style="{StaticResource ChanCb}" Margin="0,0,0,0"
                              Checked="OnChannelCheckChanged" Unchecked="OnChannelCheckChanged"/>
                </StackPanel>

                <!-- Legend (right) -->
                <StackPanel x:Name="LegendPanel" Orientation="Horizontal"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ─── CONTENT ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LAP LIST -->
            <Border Grid.Column="0" Background="#FF0E0E0E"
                    BorderBrush="#FF1E1E1E" BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- List header -->
                    <Border DockPanel.Dock="Top" Background="#FF0B0B0B"
                            Padding="12,7" BorderBrush="#FF1E1E1E" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="TOURS" FontFamily="Segoe UI Semibold"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#FF383838"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnClearTraces" Content="✕ VIDER"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource TelBtn}"
                                    FontSize="9" Padding="7,3"
                                    Click="OnClearTraces"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LapListPanel" Margin="4,6"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- CHART AREA -->
            <Grid Grid.Column="1" Background="#FF0B0B0B">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="12,10,12,4"
                        Background="#FF0E0E0E"
                        BorderBrush="#FF1E1E1E" BorderThickness="1"
                        CornerRadius="4">
                    <Canvas x:Name="ChartCanvas" SizeChanged="OnChartSizeChanged"
                            ClipToBounds="True" Cursor="Cross"
                            Background="Transparent"
                            MouseWheel="OnChartMouseWheel"
                            MouseLeftButtonDown="OnChartMouseDown"
                            MouseLeftButtonUp="OnChartMouseUp"
                            MouseMove="OnChartMouseMove"
                            MouseLeave="OnChartMouseLeave"/>
                </Border>

                <TextBlock Grid.Row="1"
                           Text="↔  Position sur le tour"
                           FontFamily="Segoe UI" FontSize="9"
                           Foreground="#FF383838"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,8"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
